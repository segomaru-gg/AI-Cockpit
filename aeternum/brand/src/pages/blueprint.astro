---
import Layout from '../layouts/Layout.astro';
import { client } from '../lib/sanity';

// Fetch tasks and group them by phase
let tasks = await client.fetch(`*[_type == "projectTask"] | order(phase asc, order asc)`);

// Fallback data for demonstration if Sanity is empty
if (tasks.length === 0) {
  tasks = [
    { _type: 'projectTask', phase: 1, title: '技術基盤の構築 (Astro 5.0)', status: 'done', description: 'Aeternumプロジェクトの土台となるAstro 5.0とSanity CMSの統合。' },
    { _type: 'projectTask', phase: 1, title: '没入型UI (5感表現) の実装', status: 'done', description: '古いテープのヒスノイズによる背景音と、View Transitionsによるシームレスな遷移。' },
    { _type: 'projectTask', phase: 1, title: 'Blueprint管理システム', status: 'doing', description: '透明性のある、この進捗管理ページの構築。' },
    { _type: 'projectTask', phase: 2, title: 'デザイン & コンテンツの物語化', status: 'pending', description: '蒐集庵・NEXUS・Journalの各セクションにおける物語の深掘りとUI統合。' },
    { _type: 'projectTask', phase: 3, title: '最終検証 & リリース', status: 'pending', description: '全体的な一貫性のチェックとパブリッシュ。' },
  ];
}

const phases = [
  { id: 1, title: 'PHASE 1: TECHNICAL FOUNDATION', desc: '技術基盤の構築' },
  { id: 2, title: 'PHASE 2: DESIGN & CONTENT', desc: 'デザイン & コンテンツ統合' },
  { id: 3, title: 'PHASE 3: TEST & RELEASE', desc: 'テスト & リリース' },
];

const getStatusLabel = (status: string) => {
  switch (status) {
    case 'done': return 'COMPLETED';
    case 'doing': return 'IN PROGRESS';
    default: return 'PENDING';
  }
};

// Progress Calculations
const calculateProgress = (taskList: any[]) => {
  if (taskList.length === 0) return 0;
  const totalWeight = taskList.length * 100;
  const progressWeight = taskList.reduce((acc, task) => {
    if (task.status === 'done') return acc + 100;
    if (task.status === 'doing') return acc + 25; // Weighted for starting
    return acc;
  }, 0);
  return Math.round((progressWeight / totalWeight) * 100);
};

const overallProgress = calculateProgress(tasks);

const phaseData = phases.map(phase => {
  const phaseTasks = tasks.filter((t: any) => t.phase === phase.id);
  return {
    ...phase,
    progress: calculateProgress(phaseTasks),
    taskCount: phaseTasks.length
  };
});
---

<Layout title="Blueprint">
  <div class="blueprint-container">
    <header class="blueprint-header fade-in-up">
      <div class="grid-lines"></div>
      <h1 class="zen-mincho">Project Blueprint</h1>
      <p class="subtitle monospace">VISUALIZING THE EVOLUTION OF AETERNUM</p>
    </header>

    <div class="blueprint-content">
      {phaseData.map((phase) => (
        <section class="phase-section fade-in-up">
          <div class="phase-header">
            <span class="phase-number monospace">0{phase.id}</span>
            <div class="phase-title-group">
              <h2 class="monospace">{phase.title}</h2>
              <p class="phase-desc">{phase.desc}</p>
            </div>
            <div class="phase-progress-indicator monospace">
              <span class="progress-bar-minimal">
                <span class="progress-fill" style={`width: ${phase.progress}%`}></span>
              </span>
              <span class="progress-value">{phase.progress}%</span>
            </div>
          </div>

          <div class="task-list">
            {tasks.filter((t: any) => t.phase === phase.id).length > 0 ? (
              tasks.filter((t: any) => t.phase === phase.id).map((task: any) => (
                <div class={`task-item ${task.status}`}>
                  <div class="task-status monospace">{getStatusLabel(task.status)}</div>
                  <div class="task-info">
                    <h3 class="task-title">{task.title}</h3>
                    {task.description && <p class="task-log">{task.description}</p>}
                  </div>
                  {task.completedAt && (
                    <div class="task-date monospace">
                      {new Date(task.completedAt).toLocaleDateString('ja-JP')}
                    </div>
                  )}
                </div>
              ))
            ) : (
              <p class="no-tasks monospace">NO DATA RECORDED IN THIS PHASE</p>
            )}
          </div>
        </section>
      ))}
    </div>

    <aside class="blueprint-sidebar fade-in-up">
      <div class="structural-info monospace">
        <div class="info-block">
          <span class="label">VERSION:</span>
          <span class="value">0.8.2-PROTO</span>
        </div>
        <div class="info-block">
          <span class="label">LAST_UPDATE:</span>
          <span class="value">{new Date().toLocaleDateString('ja-JP')}</span>
        </div>
        <div class="info-block">
          <span class="label">STATUS:</span>
          <span class="value">ACTIVE_EVOLUTION</span>
        </div>
        <div class="info-block progress-block">
          <span class="label">OVERALL_PROGRESS:</span>
          <div class="overall-progress-wrap">
            <div class="progress-track">
              <div class="progress-fill-main" style={`width: ${overallProgress}%`}></div>
            </div>
            <span class="value">{overallProgress}%</span>
          </div>
        </div>
      </div>
    </aside>
  </div>
</Layout>

<style>
  .blueprint-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 10rem 4rem;
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 6rem;
    position: relative;
  }

  .blueprint-header {
    grid-column: span 2;
    margin-bottom: 6rem;
    position: relative;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .grid-lines {
    position: absolute;
    top: -20px;
    left: -20px;
    right: -20px;
    bottom: 0;
    background-image: 
      linear-gradient(to right, rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    z-index: -1;
    mask-image: linear-gradient(to bottom, black, transparent);
  }

  h1 {
    font-size: 4rem;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .subtitle {
    font-size: 0.8rem;
    letter-spacing: 0.4em;
    color: var(--accent-primary);
    opacity: 0.8;
  }

  .monospace {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
  }

  .blueprint-content {
    display: flex;
    flex-direction: column;
    gap: 8rem;
  }

  .phase-section {
    position: relative;
  }

  .phase-header {
    display: flex;
    gap: 2rem;
    align-items: center;
    margin-bottom: 3rem;
    position: relative;
  }

  .phase-progress-indicator {
    margin-left: auto;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8px;
    min-width: 150px;
  }

  .progress-bar-minimal {
    width: 100%;
    height: 2px;
    background: rgba(255, 255, 255, 0.05);
    position: relative;
    overflow: hidden;
  }

  .progress-fill {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    background: var(--accent-primary);
    transition: width 1s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .progress-value {
    font-size: 0.7rem;
    color: var(--accent-primary);
    letter-spacing: 0.1em;
  }

  .phase-number {
    font-size: 3rem;
    line-height: 1;
    color: rgba(255, 255, 255, 0.05);
    font-weight: 700;
  }

  .phase-title-group h2 {
    font-size: 1.2rem;
    letter-spacing: 0.2em;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
  }

  .phase-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
  }

  .task-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-left: 5rem;
    border-left: 1px solid rgba(255, 255, 255, 0.05);
  }

  .task-item {
    display: grid;
    grid-template-columns: 120px 1fr 120px;
    gap: 2rem;
    align-items: center;
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.01);
    border: 1px solid rgba(255, 255, 255, 0.03);
    transition: all 0.3s ease;
  }

  .task-item:hover {
    background: rgba(255, 255, 255, 0.02);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .task-status {
    font-size: 0.65rem;
    padding: 4px 8px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    text-align: center;
    letter-spacing: 0.1em;
  }

  .task-item.done .task-status {
    border-color: var(--accent-primary);
    color: var(--accent-primary);
  }

  .task-item.doing .task-status {
    border-color: #ffd700;
    color: #ffd700;
    animation: blink 2s infinite;
  }

  @keyframes blink {
    50% { opacity: 0.4; }
  }

  .task-title {
    font-size: 1rem;
    margin-bottom: 0.5rem;
    font-weight: 500;
  }

  .task-log {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .task-date {
    font-size: 0.7rem;
    color: var(--text-muted);
    text-align: right;
  }

  .no-tasks {
    font-size: 0.7rem;
    color: var(--text-muted);
    opacity: 0.5;
    letter-spacing: 0.2em;
  }

  .blueprint-sidebar {
    padding-top: 2rem;
  }

  .structural-info {
    position: sticky;
    top: 12rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding: 2rem;
    border: 1px solid rgba(255, 255, 255, 0.05);
    background: rgba(255, 255, 255, 0.01);
  }

  .info-block {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .label {
    font-size: 0.6rem;
    color: var(--text-muted);
    letter-spacing: 0.2em;
  }

  .value {
    font-size: 0.8rem;
    color: var(--accent-primary);
  }

  .progress-block {
    margin-top: 1rem;
    padding-top: 2rem;
    border-top: 1px dashed rgba(255, 255, 255, 0.1);
  }

  .overall-progress-wrap {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .progress-track {
    flex: 1;
    height: 4px;
    background: rgba(255, 255, 255, 0.05);
    position: relative;
  }

  .progress-fill-main {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    background: var(--accent-primary);
    box-shadow: 0 0 10px rgba(var(--accent-primary-rgb), 0.3);
    transition: width 1s cubic-bezier(0.4, 0, 0.2, 1);
  }

  @media (max-width: 1000px) {
    .blueprint-container {
      grid-template-columns: 1fr;
      padding: 8rem 2rem;
    }
    .blueprint-sidebar {
      order: -1;
      margin-bottom: 4rem;
    }
    .task-item {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .task-date {
      text-align: left;
    }
    .task-list {
      padding-left: 2rem;
    }
  }
</style>

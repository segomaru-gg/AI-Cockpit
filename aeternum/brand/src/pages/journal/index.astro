---
import Layout from '../../layouts/Layout.astro';
import { client } from '../../lib/sanity';

const posts = await client.fetch(`*[_type == "post"] | order(publishedAt desc) {
  _id,
  title,
  slug,
  publishedAt,
  excerpt,
  "imageUrl": mainImage.asset->url
}`);
---

<Layout>
	<div class="journal-container">
		<header class="journal-header fade-in-up">
			<h1 class="zen-mincho">Journal</h1>
			<p class="subtitle">思索の断片、文化の備忘録</p>
		</header>

		<div class="posts-grid">
			{posts.length > 0 ? (
				posts.map((post: any, index: number) => (
					<article class={`post-card fade-in-up ${index % 3 === 0 ? 'large' : ''}`} style={`animation-delay: ${index * 0.1}s`}>
						<a href={`/journal/${post.slug?.current}`} class="post-link">
							{post.imageUrl && (
								<div class="post-image">
									<img src={post.imageUrl} alt={post.title} loading="lazy" />
								</div>
							)}
							<div class="post-meta">
								<time datetime={post.publishedAt}>
									{new Date(post.publishedAt).toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
								</time>
								<h2 class="zen-mincho">{post.title}</h2>
								<p class="excerpt">{post.excerpt}</p>
								<span class="read-more">READ MORE</span>
							</div>
						</a>
					</article>
				))
			) : (
				<div class="empty-state">
					<p>記す言葉を収蔵中です。</p>
				</div>
			)}
		</div>
	</div>
</Layout>

<style>
	.journal-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 10rem 2rem;
	}

	.journal-header {
		text-align: center;
		margin-bottom: 10rem;
	}

	h1 {
		font-size: 4rem;
		letter-spacing: 0.4em;
		margin-bottom: 2rem;
		font-weight: 500;
	}

	.subtitle {
		color: var(--text-muted);
		letter-spacing: 0.2em;
		font-size: 0.9rem;
		text-transform: uppercase;
	}

	.posts-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 8rem 4rem;
	}

	.post-card.large {
		grid-column: span 2;
		display: flex;
		gap: 4rem;
		align-items: center;
	}

	.post-card.large .post-image {
		flex: 1.5;
		aspect-ratio: 16/9;
	}

	.post-card.large .post-meta {
		flex: 1;
	}

	.post-link {
		text-decoration: none;
		color: inherit;
		display: block;
	}

	.post-image {
		width: 100%;
		aspect-ratio: 4/3;
		overflow: hidden;
		margin-bottom: 2rem;
		background: rgba(255, 255, 255, 0.02);
	}

	.post-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 1.2s cubic-bezier(0.165, 0.84, 0.44, 1);
	}

	.post-link:hover .post-image img {
		transform: scale(1.05);
	}

	.post-meta time {
		font-family: 'Zen Old Mincho', serif;
		font-size: 0.8rem;
		color: var(--accent-primary);
		display: block;
		margin-bottom: 1.5rem;
		letter-spacing: 0.1em;
	}

	.post-meta h2 {
		font-size: 2rem;
		margin-bottom: 1.5rem;
		line-height: 1.4;
		transition: color 0.3s;
	}

	.post-link:hover h2 {
		color: var(--accent-primary);
	}

	.excerpt {
		line-height: 1.8;
		color: var(--text-muted);
		font-size: 0.95rem;
		margin-bottom: 2rem;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.read-more {
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		color: var(--text-primary);
		border-bottom: 1px solid var(--accent-primary);
		padding-bottom: 4px;
		opacity: 0.6;
		transition: opacity 0.3s;
	}

	.post-link:hover .read-more {
		opacity: 1;
	}

	.empty-state {
		grid-column: span 2;
		text-align: center;
		padding: 10rem 0;
		color: var(--text-muted);
		border: 1px dashed rgba(255, 255, 255, 0.05);
	}

	@media (max-width: 900px) {
		.posts-grid {
			grid-template-columns: 1fr;
			gap: 6rem;
		}
		.post-card.large {
			grid-column: span 1;
			flex-direction: column;
			gap: 0;
		}
		h1 {
			font-size: 2.5rem;
		}
	}
</style>

---
interface Props {
	title: string;
	status: 'pending' | 'doing' | 'done';
	priority?: 'low' | 'medium' | 'high';
	phase: string;
}

const { title, status, priority, phase } = Astro.props;

const statusEmoji = {
	pending: '○',
	doing: '◐',
	done: '●'
};
---

<div class={`task-card ${status}`}>
	<div class="task-header">
		<span class="status-marker">{statusEmoji[status]}</span>
		<h3 class="task-title">{title}</h3>
	</div>
	<div class="task-footer">
		<span class="task-phase">{phase}</span>
		{priority && <span class={`priority ${priority}`}>[{priority.toUpperCase()}]</span>}
	</div>
</div>

<style>
	.task-card {
		border: 1px solid var(--border);
		padding: 1rem;
		background: rgba(0, 0, 0, 0.2);
		margin-bottom: 1rem;
		transition: border-color 0.2s ease, transform 0.2s ease;
		position: relative;
	}

	.task-card:hover {
		border-color: var(--accent);
		transform: translateX(4px);
	}

	.task-card::before {
		content: '';
		position: absolute;
		top: -1px;
		left: -1px;
		width: 10px;
		height: 10px;
		border-top: 1px solid var(--muted);
		border-left: 1px solid var(--muted);
	}

	.task-header {
		display: flex;
		align-items: flex-start;
		gap: 1rem;
		margin-bottom: 0.5rem;
	}

	.status-marker {
		font-size: 1.2rem;
		line-height: 1;
		color: var(--accent);
	}

	.task-title {
		font-size: 1rem;
		font-family: var(--font-mono);
		color: var(--fg);
		margin: 0;
	}

	.task-footer {
		display: flex;
		justify-content: space-between;
		font-size: 0.7rem;
		color: var(--muted);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.priority.high { color: #ff5555; }
	.priority.medium { color: #ffb86c; }
	.priority.low { color: #50fa7b; }

	.task-card.done {
		opacity: 0.6;
	}
	
	.task-card.doing {
		border-color: var(--accent);
	}
</style>

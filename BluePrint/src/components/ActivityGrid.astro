---
interface Props {
	activity: Record<string, number>;
	size?: 'small' | 'large';
}

const { activity, size = 'small' } = Astro.props;

// Generate last 12 weeks of data
const daysToDisplay = size === 'large' ? 120 : 56; // 17 weeks for large, 8 weeks for small
const today = new Date();
today.setHours(0, 0, 0, 0);

const days = Array.from({ length: daysToDisplay }).map((_, i) => {
	const d = new Date(today);
	d.setDate(today.getDate() - (daysToDisplay - 1 - i));
	
	// Format as YYYY-MM-DD in local time
	const year = d.getFullYear();
	const month = String(d.getMonth() + 1).padStart(2, '0');
	const date = String(d.getDate()).padStart(2, '0');
	const dateStr = `${year}-${month}-${date}`;
	
	const count = activity[dateStr] || 0;
    
    let level = 0;
    if (count > 0) level = 1;
    if (count >= 2) level = 2;
    if (count >= 4) level = 3;
    if (count >= 6) level = 4;

	return { dateStr, count, level };
});

// Group by weeks for vertical columns
const weeks: any[][] = [];
let currentWeek: any[] = [];

// Align the first week (padding if necessary)
const firstDate = new Date(days[0].dateStr);
const padding = firstDate.getDay(); // 0 is Sunday
for (let i = 0; i < padding; i++) {
    currentWeek.push(null);
}

days.forEach(day => {
    currentWeek.push(day);
    if (currentWeek.length === 7) {
        weeks.push(currentWeek);
        currentWeek = [];
    }
});
if (currentWeek.length > 0) {
    while (currentWeek.length < 7) currentWeek.push(null);
    weeks.push(currentWeek);
}

---

<div class={`activity-grid-container ${size}`}>
	<div class="grid-wrapper">
		{weeks.map(week => (
			<div class="week-column">
				{week.map(day => (
					<div 
						class={`day-cell level-${day ? day.level : 'empty'}`} 
						title={day ? `${day.dateStr}: ${day.count} events` : ''}
					></div>
				))}
			</div>
		))}
	</div>
</div>

<style>
	.activity-grid-container {
		display: inline-block;
	}

	.grid-wrapper {
		display: flex;
		gap: 3px;
	}

	.week-column {
		display: flex;
		flex-direction: column;
		gap: 3px;
	}

	.day-cell {
		width: 10px;
		height: 10px;
		border-radius: 1px;
		background: var(--border);
		transition: transform 0.2s ease;
	}

    .day-cell.level-empty {
        opacity: 0;
    }

	.day-cell.level-0 { background: #161b22; }
	.day-cell.level-1 { background: #0e4429; }
	.day-cell.level-2 { background: #006d32; }
	.day-cell.level-3 { background: #26a641; }
	.day-cell.level-4 { background: #39d353; }

    /* Alternate Blueprint Theme colors for higher levels if preferred */
    .activity-grid-container.blueprint .day-cell.level-4 {
        background: var(--accent);
        box-shadow: 0 0 5px var(--accent);
    }

	.day-cell:hover {
		transform: scale(1.3);
		z-index: 10;
		outline: 1px solid white;
	}

	/* Large size adjustments */
	.activity-grid-container.large .day-cell {
		width: 12px;
		height: 12px;
	}
    
    .activity-grid-container.large .grid-wrapper {
        gap: 4px;
    }
    
    .activity-grid-container.large .week-column {
        gap: 4px;
    }
</style>

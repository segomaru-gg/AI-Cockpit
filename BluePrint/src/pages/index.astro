---
import Layout from '../layouts/Layout.astro';
import TaskCard from '../components/TaskCard.astro';
import ProgressBar from '../components/ProgressBar.astro';
import { discoverProjects } from '../lib/projects';

const projects = await discoverProjects('../');

// Aggregate statistics
const allTasks = projects.flatMap(p => p.tasks);
const projectStats = {
	total: allTasks.length,
	done: allTasks.filter(t => t.status === 'done').length,
	doing: allTasks.filter(t => t.status === 'doing').length,
	projectsCount: projects.length,
};

const overallProgress = projectStats.total > 0 
	? ((projectStats.done + projectStats.doing * 0.5) / projectStats.total) * 100 
	: 0;

const getAdvice = (pct: number, tasks: any[] = []) => {
	const today = new Date();
	today.setHours(0, 0, 0, 0);

	const activeTasks = tasks.filter(t => t.status !== 'done');
	
	// 1. Critical Check: Overdue High Priority Tasks
	const overdueHigh = activeTasks.find(t => {
		if (!t.deadline) return false;
		const d = new Date(t.deadline);
		return t.priority === 'high' && d < today;
	});
	if (overdueHigh) return `[CRITICAL] 高優先タスクの期限 (${overdueHigh.deadline}) を超過しています。リソースを集中投下してください。`;

	// 2. Urgent Check: Near Deadlines (within 2 days)
	const twoDaysFromNow = new Date();
	twoDaysFromNow.setDate(today.getDate() + 2);
	
	const urgentTask = activeTasks.find(t => {
		if (!t.deadline) return false;
		const d = new Date(t.deadline);
		return d <= twoDaysFromNow;
	});
	if (urgentTask) return `[URGENT] 近々の期限 (${urgentTask.deadline}) が迫っています。現在の作業ピッチを上げてください。`;

	// 3. High Prioriy Work Check
	const hasHigh = activeTasks.some(t => t.priority === 'high');
	if (hasHigh) return "重要度の高いミッションが進行中です。確実な品質での完遂を目指しましょう。";

	// 4. Default Progress Based Advice
	if (pct < 40) return "始動期です。まずは目前の pending タスクを doing に移行させ、初速を上げましょう。";
	if (pct < 80) return "安定期です。このリズムを維持しつつ、次フェーズの準備も並行して進めてください。";
	
	return "収束期に入りました。残存タスクの仕上げと、成果物のメタ分析を開始しましょう。";
};

// Domain-specific statistics
const getCategoryStats = (cat: string) => {
	const catProjects = projects.filter(p => p.category === cat);
	const catTasks = catProjects.flatMap(p => p.tasks);
	if (catTasks.length === 0) return null;
	const done = catTasks.filter(t => t.status === 'done').length;
	const doing = catTasks.filter(t => t.status === 'doing').length;
	const points = done + doing * 0.5;
	return {
		done,
		total: catTasks.length,
		pct: Math.round((points / catTasks.length) * 100)
	};
};

---

<Layout title="Cockpit Dashboard">
	<header class="dashboard-header">
		<div class="header-main">
			<div class="project-info">
				<span class="system-label">UNIFIED_COCKPIT // GLOBAL_VIEW</span>
				<h1>Master Control Dashboard</h1>
			</div>
			<div class="stats-grid">
				<div class="stat-item">
					<span class="label">ACTIVE_PROJECTS</span>
					<span class="value">{projectStats.projectsCount}</span>
				</div>
				<div class="stat-item">
					<span class="label">VERSION</span>
					<span class="value">v2.1.3</span>
				</div>
				<div class="stat-item">
					<span class="label">GLOBAL_TASKS</span>
					<span class="value">{projectStats.done}/{projectStats.total}</span>
				</div>
			</div>
		</div>
		
		<ProgressBar 
			progress={overallProgress} 
			label="Overall Completion" 
			advice={getAdvice(overallProgress, allTasks)}
		/>

		<nav class="filter-bar">
			<div class="filter-main">
				<span class="system-label">FILTER_DOMAIN /</span>
				<div class="filter-buttons">
				<button class="filter-btn active cat-all" data-filter="all">
					ALL
					<span class="btn-stats">{projectStats.done}/{projectStats.total}</span>
				</button>
				{['business', 'ops', 'brand', 'personal'].map(cat => {
					const stats = getCategoryStats(cat);
					return stats && (
						<button class={`filter-btn cat-${cat}`} data-filter={cat}>
							{cat}
							<span class="btn-stats">{stats.done}/{stats.total} ({stats.pct}%)</span>
						</button>
					);
				})}
			</div>
			<div class="search-box">
				<span class="system-label">SEARCH_QUERY_STABLE:</span>
				<input type="text" id="dashboard-search" placeholder="Type to filter projects..." />
			</div>
		</nav>
	</header>

	<div class="blueprint-grid" id="project-grid">
		{projects.map(project => (
			<section class="project-section" data-category={project.category}>
				<div class="project-header">
					<div class="project-meta">
						<span class={`category-badge cat-${project.category}`}>{project.category}</span>
						<span class="system-label">PROJECT_MODULE</span>
						{project.dashboardUrl ? (
							<a href={project.dashboardUrl} class="project-link" target="_blank">
								<h2>{project.name} <span class="link-icon">↗</span></h2>
							</a>
						) : (
							<h2>{project.name}</h2>
						)}
					</div>
					<ProgressBar 
						progress={project.progress} 
						label="Project Progress"
						advice={getAdvice(project.progress, project.tasks)}
					/>
					{project.latestLog && (
						<div class="latest-log">
							<span class="log-title">LATEST_LOG: {project.latestLog}</span>
							{project.latestLogPreview && <p class="log-content">{project.latestLogPreview}</p>}
							{project.latestLogFull && (
								<button 
									class="view-log-btn" 
									data-log-title={project.latestLog} 
									data-log-body={project.latestLogFull}
								>
									[VIEW_FULL_LOG]
								</button>
							)}
						</div>
					)}
				</div>
				<div class="task-list">
					{project.tasks
						.sort((a, b) => (a.order ?? 999) - (b.order ?? 999))
						.map(task => (
							<TaskCard 
								title={task.title}
								status={task.status}
								priority={task.priority}
								phase={task.phase}
								content={task.content}
								deadline={task.deadline}
							/>
						))
					}
					{project.tasks.length === 0 && (
						<div class="empty-state">NO TASKS DEFINED</div>
					)}
				</div>
			</section>
		))}
	</div>

	<footer class="dashboard-footer">
		<div class="footer-line"></div>
		<div class="footer-content">
			<span>COCKPIT_LINK_STABLE</span>
			<span>MULTI_DOMAIN // AGGREGATED</span>
			<span>{new Date().toISOString()}</span>
		</div>
	</footer>

	<!-- Journal Modal -->
	<div id="journal-modal" class="modal-overlay">
		<div class="modal-container">
			<header class="modal-header">
				<h2 id="modal-log-title">LOG_TITLE</h2>
				<button id="close-journal-modal" class="close-btn">CLOSE [X]</button>
			</header>
			<div class="modal-body">
				<pre id="modal-log-content"></pre>
			</div>
		</div>
	</div>

	<!-- Task Detail Modal -->
	<div id="task-modal" class="modal-overlay">
		<div class="modal-container task-modal-container">
			<header class="modal-header">
				<h2 id="modal-task-title">TASK_TITLE</h2>
				<button id="close-task-modal" class="close-btn">CLOSE [X]</button>
			</header>
			<div class="modal-body">
				<div id="modal-task-content" class="markdown-body"></div>
			</div>
		</div>
	</div>
</Layout>

<style>
	.dashboard-header {
		margin-bottom: 4rem;
		border-bottom: 2px solid var(--accent);
		padding-bottom: 2rem;
		position: relative;
	}

	.dashboard-header::after {
		content: '';
		position: absolute;
		bottom: -10px;
		left: 0;
		width: 100%;
		height: 1px;
		background: var(--border);
	}

	.header-main {
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		margin-bottom: 2rem;
	}

	.system-label {
		font-size: 0.7rem;
		color: var(--muted);
		display: block;
		margin-bottom: 0.5rem;
		letter-spacing: 0.2em;
	}

	h1 {
		font-size: 2.5rem;
		margin: 0;
		font-weight: 800;
	}

	.stats-grid {
		display: flex;
		gap: 2rem;
	}

	.stat-item {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
	}

	.stat-item .label {
		font-size: 0.6rem;
		color: var(--muted);
		letter-spacing: 0.1em;
	}

	.stat-item .value {
		font-size: 1.2rem;
		font-weight: 700;
		color: var(--accent);
	}

	.filter-bar {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 2rem;
		margin-top: 2rem;
		border-top: 1px solid var(--border);
		padding-top: 1.5rem;
		flex-wrap: wrap;
	}

	.filter-main {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.search-box {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		flex: 1;
		max-width: 400px;
	}

	.search-box input {
		background: transparent;
		border: 1px solid var(--border);
		color: var(--fg);
		font-family: var(--font-mono);
		font-size: 0.75rem;
		padding: 4px 12px;
		width: 100%;
		border-radius: 2px;
		transition: border-color 0.2s ease;
	}

	.search-box input:focus {
		outline: none;
		border-color: var(--accent);
	}

	.filter-buttons {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.blueprint-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
		gap: 4rem;
	}

	.project-section {
		display: flex;
		flex-direction: column;
	}

	.project-header {
		margin-bottom: 2rem;
		position: relative;
	}

	.project-meta {
		display: flex;
		flex-direction: column;
		margin-bottom: 1rem;
	}

	.project-link {
		text-decoration: none;
		color: inherit;
		display: inline-block;
		transition: transform 0.2s ease;
	}

	.project-link:hover {
		transform: translateX(4px);
	}

	.project-link h2 {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.link-icon {
		font-size: 0.8rem;
		opacity: 0;
		color: var(--accent);
		transition: opacity 0.2s ease;
	}

	.project-link:hover .link-icon {
		opacity: 1;
	}

	.category-badge, .filter-btn {
		font-size: 0.6rem;
		background: var(--border);
		color: var(--muted);
		padding: 2px 8px;
		width: fit-content;
		text-transform: uppercase;
		font-weight: 700;
		letter-spacing: 0.1em;
		border-radius: 2px;
		border: none;
		font-family: var(--font-mono);
		cursor: pointer;
		transition: all 0.2s ease;
	}

	.category-badge {
		margin-bottom: 0.5rem;
		cursor: default;
	}

	.filter-btn {
		opacity: 0.4;
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.btn-stats {
		font-size: 0.5rem;
		opacity: 0.7;
		background: rgba(0,0,0,0.1);
		padding: 1px 4px;
		border-radius: 2px;
	}

	.cat-all .btn-stats {
		background: rgba(0,0,0,0.05);
	}

	.filter-btn:hover, .filter-btn.active {
		opacity: 1;
	}

	.cat-all {
		background: #ffffff; /* Pure White */
		color: #000000;
	}

	.cat-business {
		background: #ff4d4d; /* Bright Red */
		color: white;
	}

	.cat-ops {
		background: #ffd700; /* Gold/Yellow */
		color: black;
	}

	.cat-personal {
		background: #00ff7f; /* Spring Green */
		color: black;
	}

	.cat-brand {
		background: #9370db; /* Medium Purple */
		color: white;
	}

	.filter-btn.active {
		box-shadow: 0 0 10px currentColor;
		outline: 1px solid var(--fg);
	}

	.project-meta h2 {
		font-size: 1.4rem;
		margin: 0;
		color: var(--accent);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.latest-log {
		margin-top: 1.5rem;
		padding-top: 1rem;
		border-top: 1px solid var(--border);
	}

	.latest-log .log-title {
		display: block;
		font-size: 0.7rem;
		color: var(--muted);
		text-transform: uppercase;
		margin-bottom: 0.4rem;
	}

	.latest-log .log-content {
		font-size: 0.85rem;
		color: var(--fg);
		line-height: 1.5;
		opacity: 0.8;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.log-title {
		color: var(--fg);
	}

	.view-log-btn {
		background: none;
		border: 1px solid var(--muted);
		color: var(--muted);
		font-family: var(--font-mono);
		font-size: 0.6rem;
		padding: 2px 8px;
		margin-top: 0.8rem;
		cursor: pointer;
		transition: all 0.2s ease;
		text-transform: uppercase;
	}

	.view-log-btn:hover {
		color: var(--accent);
		border-color: var(--accent);
		background: rgba(255, 255, 255, 0.05);
	}

	/* Modal Styles */
	.modal-overlay {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: rgba(0, 0, 0, 0.85);
		backdrop-filter: blur(8px);
		display: none;
		justify-content: center;
		align-items: center;
		z-index: 1000;
		padding: 2rem;
	}

	.modal-overlay.active {
		display: flex;
	}

	.modal-container {
		background: #0f1115;
		border: 1px solid var(--accent);
		width: 100%;
		max-width: 800px;
		max-height: 80vh;
		display: flex;
		flex-direction: column;
		box-shadow: 0 0 30px rgba(255, 255, 255, 0.1);
	}

	.modal-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1.5rem;
		border-bottom: 1px solid var(--border);
	}

	.modal-header h2 {
		font-size: 1rem;
		margin: 0;
		color: var(--accent);
	}

	.close-btn {
		background: none;
		border: none;
		color: var(--muted);
		font-family: var(--font-mono);
		font-size: 0.7rem;
		cursor: pointer;
	}

	.close-btn:hover {
		color: #ff4d4d;
	}

	.modal-body {
		padding: 2rem;
		overflow-y: auto;
		flex-grow: 1;
	}

	#modal-log-content {
		white-space: pre-wrap;
		font-family: var(--font-mono);
		font-size: 0.9rem;
		line-height: 1.6;
		color: var(--fg);
		opacity: 0.9;
	}

	.task-list {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.empty-state {
		font-size: 0.7rem;
		color: var(--muted);
		padding: 1rem;
		border: 1px dashed var(--border);
		text-align: center;
		letter-spacing: 0.2em;
	}

	.dashboard-footer {
		margin-top: 6rem;
	}

	.footer-line {
		height: 1px;
		background: var(--border);
		margin-bottom: 1rem;
	}

	.footer-content {
		display: flex;
		justify-content: space-between;
		font-size: 0.6rem;
		color: var(--muted);
		letter-spacing: 0.1em;
	}
</style>

<script>
	const filterButtons = document.querySelectorAll('.filter-btn');
	const searchInput = document.getElementById('dashboard-search') as HTMLInputElement;
	const projects = document.querySelectorAll('.project-section');

	let activeFilter = 'all';
	let searchQuery = '';

	function updateFilters() {
		projects.forEach(project => {
			const projectEl = project as HTMLElement;
			const category = projectEl.getAttribute('data-category');
			const content = projectEl.innerText.toLowerCase();
			
			const matchesCategory = activeFilter === 'all' || category === activeFilter;
			const matchesSearch = searchQuery === '' || content.includes(searchQuery.toLowerCase());

			if (matchesCategory && matchesSearch) {
				projectEl.style.display = 'flex';
			} else {
				projectEl.style.display = 'none';
			}
		});
	}

	filterButtons.forEach(btn => {
		btn.addEventListener('click', () => {
			const filter = btn.getAttribute('data-filter');
			if (!filter) return;
			
			activeFilter = filter;

			// Update active button
			filterButtons.forEach(b => b.classList.remove('active'));
			btn.classList.add('active');

			updateFilters();
		});
	});

	searchInput?.addEventListener('input', (e) => {
		searchQuery = (e.target as HTMLInputElement).value;
		updateFilters();
	});

	// Modal Logic
	const journalModal = document.getElementById('journal-modal');
	const taskModal = document.getElementById('task-modal');
	const closeJournalBtn = document.getElementById('close-journal-modal');
	const closeTaskBtn = document.getElementById('close-task-modal');
	
	const modalLogTitle = document.getElementById('modal-log-title');
	const modalLogContent = document.getElementById('modal-log-content');
	const viewLogBtns = document.querySelectorAll('.view-log-btn');

	const modalTaskTitle = document.getElementById('modal-task-title');
	const modalTaskContent = document.getElementById('modal-task-content');
	const taskCards = document.querySelectorAll('.task-card');

	// Journal Modal Trigger
	viewLogBtns.forEach(btn => {
		btn.addEventListener('click', (e) => {
			e.stopPropagation();
			const title = btn.getAttribute('data-log-title');
			const body = btn.getAttribute('data-log-body');
			
			if (modalLogTitle) modalLogTitle.innerText = title || '';
			if (modalLogContent) modalLogContent.innerText = body || '';
			
			journalModal?.classList.add('active');
			document.body.style.overflow = 'hidden';
		});
	});

	// Task Modal Trigger (Click)
	taskCards.forEach(card => {
		card.addEventListener('click', () => {
			const title = card.getAttribute('data-task-title');
			const content = card.getAttribute('data-task-content');
			
			if (modalTaskTitle) modalTaskTitle.innerText = title || '';
			// Simple formatting for task content (handle frontmatter removal if any)
			if (modalTaskContent) {
				const displayContent = content ? content.replace(/^---[\s\S]*?---\n?/, '').trim() : 'NO CONTENT';
				modalTaskContent.innerText = displayContent;
			}
			
			taskModal?.classList.add('active');
			document.body.style.overflow = 'hidden';
		});
		
		// Visual indicator for interactivity
		(card as HTMLElement).style.cursor = 'pointer';
	});

	// Close Logic
	closeJournalBtn?.addEventListener('click', () => {
		journalModal?.classList.remove('active');
		document.body.style.overflow = 'auto';
	});

	closeTaskBtn?.addEventListener('click', () => {
		taskModal?.classList.remove('active');
		document.body.style.overflow = 'auto';
	});

	// Close on BG click
	window.addEventListener('click', (e) => {
		if (e.target === journalModal) {
			journalModal?.classList.remove('active');
			document.body.style.overflow = 'auto';
		}
		if (e.target === taskModal) {
			taskModal?.classList.remove('active');
			document.body.style.overflow = 'auto';
		}
	});
</script>

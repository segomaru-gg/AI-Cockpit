---
import MobileLayout from "../layouts/MobileLayout.astro";
import { discoverProjects, type Task } from "../lib/projects";
import path from "node:path";

// Server-Side Logic
const COCKPIT_ROOT = path.resolve(process.cwd(), "../");
const projects = await discoverProjects(COCKPIT_ROOT);

// Find "Doing" tasks across all projects
const doingTasks: Task[] = [];
projects.forEach((p) => {
    // Check goal phases first
    if (p.activeGoal) {
        p.activeGoal.phases.forEach((ph) => {
            ph.tasks.forEach((t) => {
                if (t.status === "doing")
                    doingTasks.push({
                        ...t,
                        project: p.name,
                        projectColor: "blue",
                    });
            });
        });
    }
    // Check root tasks (legacy/simple)
    p.tasks.forEach((t) => {
        if (t.status === "doing")
            doingTasks.push({ ...t, project: p.name, projectColor: "blue" });
    });
});

// Select the primary focus
const hasFocus = doingTasks.length > 0;
const currentTask = hasFocus ? doingTasks[0] : null;

// If no focus, find pending candidates (e.g., from BluePrint)
let pendingTasks: Task[] = [];
if (!hasFocus) {
    const blueprint = projects.find((p) => p.name === "BluePrint");
    if (blueprint && blueprint.activeGoal) {
        blueprint.activeGoal.phases.forEach((ph) => {
            if (ph.status === "active") {
                ph.tasks
                    .filter((t) => t.status === "pending")
                    .forEach((t) => pendingTasks.push(t));
            }
        });
    }
}
---

<MobileLayout title="Focus Mode | BluePrint">
    <main
        class="h-screen w-screen flex flex-col items-center justify-center p-6 relative overflow-hidden"
    >
        <!-- Ambient Background -->
        <div
            class="absolute inset-0 bg-gradient-to-b from-gray-900 via-gray-900 to-black z-0"
        >
        </div>
        <div
            class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-blue-900/20 via-transparent to-transparent z-0 opacity-50"
        >
        </div>

        <div
            class="w-full max-w-md space-y-8 text-center relative z-10 flex flex-col h-full justify-between py-8"
        >
            {/* Header Section */}
            <div class="space-y-4 mt-8">
                <h1
                    class="text-xs font-mono text-blue-300/60 uppercase tracking-[0.3em]"
                >
                    Current Objective
                </h1>
                {
                    hasFocus && currentTask ? (
                        <div class="text-3xl font-bold text-white drop-shadow-lg leading-tight">
                            {currentTask.title}
                        </div>
                    ) : (
                        <div class="text-2xl font-bold text-gray-400">
                            All Clear
                        </div>
                    )
                }
            </div>

            {/* Main Card Section */}
            <div
                class="flex-grow flex items-center justify-center w-full relative"
            >
                {
                    hasFocus && currentTask ? (
                        <div
                            class="w-full bg-gray-800/50 backdrop-blur-xl p-8 rounded-3xl shadow-2xl border border-white/10 ring-1 ring-white/5 space-y-6 transition-all duration-500"
                            id="focus-card"
                        >
                            <div class="text-left space-y-2">
                                <div class="flex items-center space-x-2">
                                    <span class="w-2 h-2 rounded-full bg-blue-500 animate-pulse" />
                                    <span class="text-xs font-mono text-gray-400 uppercase">
                                        {currentTask.project}
                                    </span>
                                </div>
                                <div class="prose prose-invert max-w-none text-sm opacity-80 line-clamp-4">
                                    {/* Simple content preview if available, else just title below */}
                                </div>
                            </div>

                            <form
                                id="complete-form"
                                method="POST"
                                action="/api/task/complete"
                                class="w-full"
                            >
                                <input
                                    type="hidden"
                                    name="taskId"
                                    value={currentTask.id}
                                />
                                <input
                                    type="hidden"
                                    name="filePath"
                                    value={currentTask.filePath}
                                />

                                <button
                                    type="submit"
                                    id="complete-btn"
                                    class="w-full py-5 bg-gradient-to-r from-blue-600 to-blue-500 hover:from-blue-500 hover:to-blue-400 text-white rounded-2xl font-bold text-lg shadow-lg shadow-blue-900/30 transition-all active:scale-95 touch-manipulation relative overflow-hidden group"
                                >
                                    <span class="relative z-10">
                                        MISSION COMPLETE
                                    </span>
                                    <div class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300" />
                                </button>
                            </form>
                        </div>
                    ) : (
                        <div class="w-full bg-gray-800/30 backdrop-blur-md p-6 rounded-3xl border border-white/5 animate-in fade-in slide-in-from-bottom-4 duration-500">
                            <h2 class="text-xl font-bold text-white mb-2">
                                Excellent Work!
                            </h2>
                            <p class="text-gray-400 mb-6 text-sm">
                                Ready for the next objective?
                            </p>
                            <div class="space-y-3 max-h-[40vh] overflow-y-auto no-scrollbar">
                                {pendingTasks.slice(0, 5).map((t) => (
                                    <div class="p-4 bg-gray-700/40 rounded-xl hover:bg-gray-700/60 active:bg-gray-700 cursor-pointer transition-all border border-white/5 text-left group">
                                        <div class="text-sm font-semibold text-gray-200 group-hover:text-white">
                                            {t.title}
                                        </div>
                                        <div class="flex justify-between mt-1">
                                            <div class="text-[10px] text-gray-500 uppercase tracking-wider">
                                                {t.phase}
                                            </div>
                                            <div class="text-[10px] text-blue-400 opacity-0 group-hover:opacity-100 transition-opacity">
                                                START MISSION →
                                            </div>
                                        </div>
                                    </div>
                                ))}
                            </div>
                        </div>
                    )
                }
            </div>

            <script>
                import confetti from "canvas-confetti";

                const completeBtn = document.getElementById("complete-btn");
                const form = document.getElementById(
                    "complete-form"
                ) as HTMLFormElement;

                if (completeBtn && form) {
                    completeBtn.addEventListener("click", async (e) => {
                        e.preventDefault();

                        // 1. Visual Celebration
                        const rect = completeBtn.getBoundingClientRect();
                        const x =
                            (rect.left + rect.width / 2) / window.innerWidth;
                        const y =
                            (rect.top + rect.height / 2) / window.innerHeight;

                        confetti({
                            particleCount: 150,
                            spread: 70,
                            origin: { x, y },
                            colors: [
                                "#3b82f6",
                                "#60a5fa",
                                "#93c5fd",
                                "#ffffff",
                            ],
                            disableForReducedMotion: true,
                        });

                        // 2. Submit Logic
                        completeBtn.textContent = "SYNCING...";
                        completeBtn.classList.add("opacity-75", "cursor-wait");

                        try {
                            const formData = new FormData(form);
                            const response = await fetch(form.action, {
                                method: "POST",
                                body: formData,
                                headers: {
                                    Accept: "application/json",
                                },
                            });

                            if (response.ok) {
                                // 3. Redirect/Reload to show next state
                                setTimeout(() => {
                                    window.location.reload();
                                }, 800);
                            } else {
                                alert("Failed to sync. Please try again.");
                                completeBtn.textContent = "RETRY";
                            }
                        } catch (err) {
                            console.error(err);
                            alert("Offline? Check connection.");
                        }
                    });
                }
            </script>

            {/* Footer */}
            <div class="pb-4">
                <a
                    href="/"
                    class="inline-flex items-center text-xs text-gray-600 hover:text-gray-400 transition-colors uppercase tracking-widest gap-2"
                >
                    <span>●</span> Dashboard
                </a>
            </div>
        </div>
    </main>
</MobileLayout>

		padding-bottom: 1rem;
		border-bottom: 1px solid var(--border);
	}

	.global-identity h1 {
		font-size: 1.8rem;
		font-weight: 800;
		color: var(--fg);
		margin: 0;
		line-height: 1;
	}

	.system-meta {
		text-align: right;
	}

	.section-label {
		display: block;
		font-size: 0.7rem;

		padding: 0.2rem 0.5rem;
		border-radius: 0.25rem;
		flex-shrink: 0;
	}

	.goal-info {
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
	}

	.goal-name {
		font-weight: 700;
		font-size: 0.95rem;
		color: var(--fg);
	}

	.goal-desc {
		font-size: 0.75rem;
		color: var(--muted);
		line-height: 1.4;
	}

	/* Alignment Badge */
	.alignment-badge {
		font-size: 0.65rem;
		letter-spacing: 0.05em;
		color: #f59e0b;
		opacity: 0.8;
	}

	.category-badge,
	.filter-btn {
		font-size: 0.6rem;
		background: var(--border);
		color: var(--muted);
		padding: 2px 8px;

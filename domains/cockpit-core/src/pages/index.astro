		margin-bottom: 1rem;
	}

	.global-goals-list {
		display: flex;
		gap: 1rem;
		margin-top: 0.75rem;
		flex-wrap: wrap;
	}

	.global-goal-card {
		display: flex;
		align-items: flex-start;
		gap: 0.75rem;
		flex: 1;
		min-width: 280px;
		padding: 1rem;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 0.5rem;
	}


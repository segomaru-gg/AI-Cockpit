		opacity: 0;
		color: var(--accent);
		transition: opacity 0.2s ease;
	}

	.project-link:hover .link-icon {
		opacity: 1;
	}

	/* Global Goals Section */
	.global-goals-section {
		padding: 1.5rem;
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid rgba(255, 255, 255, 0.06);

</style>

<script>
	const filterButtons = document.querySelectorAll(".filter-btn");
	const searchInput = document.getElementById(
		"dashboard-search"
	) as HTMLInputElement;
	const projects = document.querySelectorAll(".project-section");

	let activeFilter = "all";
	let searchQuery = "";

	function updateFilters() {
		projects.forEach((project) => {
			const projectEl = project as HTMLElement;
			const category = projectEl.getAttribute("data-category");
			const content = projectEl.innerText.toLowerCase();

			const matchesCategory =
				activeFilter === "all" || category === activeFilter;
			const matchesSearch =
				searchQuery === "" ||
				content.includes(searchQuery.toLowerCase());

			if (matchesCategory && matchesSearch) {
				projectEl.style.display = "flex";
			} else {
				projectEl.style.display = "none";
			}
		});
	}

	filterButtons.forEach((btn) => {
		btn.addEventListener("click", () => {
			const filter = btn.getAttribute("data-filter");
			if (!filter) return;

			activeFilter = filter;

			// Update active button
			filterButtons.forEach((b) => b.classList.remove("active"));
			btn.classList.add("active");

			updateFilters();
		});
	});

	searchInput?.addEventListener("input", (e) => {
		searchQuery = (e.target as HTMLInputElement).value;
		updateFilters();
	});

	// Modal Logic
	const journalModal = document.getElementById("journal-modal");
	const taskModal = document.getElementById("task-modal");
	const closeJournalBtn = document.getElementById("close-journal-modal");
	const closeTaskBtn = document.getElementById("close-task-modal");

	const modalLogTitle = document.getElementById("modal-log-title");
	const modalLogContent = document.getElementById("modal-log-content");
	const viewLogBtns = document.querySelectorAll(".view-log-btn");

	const modalTaskTitle = document.getElementById("modal-task-title");
	const modalTaskContent = document.getElementById("modal-task-content");
	const taskCards = document.querySelectorAll(".task-card");

	// Journal Modal Trigger
	viewLogBtns.forEach((btn) => {
		btn.addEventListener("click", (e) => {
			e.stopPropagation();
			const title = btn.getAttribute("data-log-title");
			const body = btn.getAttribute("data-log-body");

			if (modalLogTitle) modalLogTitle.innerText = title || "";
			if (modalLogContent) modalLogContent.innerText = body || "";

			journalModal?.classList.add("active");
			document.body.style.overflow = "hidden";
		});
	});

	// Task Modal Trigger (Click)
	taskCards.forEach((card) => {
		card.addEventListener("click", () => {
			const title = card.getAttribute("data-task-title");
			const content = card.getAttribute("data-task-content");

			if (modalTaskTitle) modalTaskTitle.innerText = title || "";
			// Simple formatting for task content (handle frontmatter removal if any)
			if (modalTaskContent) {
				const displayContent = content
					? content.replace(/^---[\s\S]*?---\n?/, "").trim()
					: "NO CONTENT";
				modalTaskContent.innerText = displayContent;
			}

			taskModal?.classList.add("active");
			document.body.style.overflow = "hidden";
		});

		// Visual indicator for interactivity
		(card as HTMLElement).style.cursor = "pointer";
	});

	// Close Logic
	closeJournalBtn?.addEventListener("click", () => {
		journalModal?.classList.remove("active");
		document.body.style.overflow = "auto";
	});

	closeTaskBtn?.addEventListener("click", () => {
		taskModal?.classList.remove("active");
		document.body.style.overflow = "auto";
	});

	// Close on BG click
	window.addEventListener("click", (e) => {
		if (e.target === journalModal) {
			journalModal?.classList.remove("active");
			document.body.style.overflow = "auto";
		}
		if (e.target === taskModal) {
			taskModal?.classList.remove("active");
			document.body.style.overflow = "auto";
		}
		if (e.target === phaseModal) {
			phaseModal?.classList.remove("active");
			document.body.style.overflow = "auto";
		}
	});

	// Phase Modal Logic
	const phaseModal = document.getElementById("phase-modal");
	const closePhaseBtn = document.getElementById("close-phase-modal");
	const modalPhaseTitle = document.getElementById("modal-phase-title");
	const modalPhaseContent = document.getElementById("modal-phase-content");
	const phaseCards = document.querySelectorAll(".phase-card");

	phaseCards.forEach((card) => {
		card.addEventListener("click", () => {
			const name = card.getAttribute("data-phase-name");
			const status = card.getAttribute("data-phase-status");
			const tasksJson = card.getAttribute("data-phase-tasks");
			
			if (modalPhaseTitle) {
				modalPhaseTitle.innerHTML = `${name} <span style="font-size: 0.6em; margin-left:1rem; opacity:0.7; padding:2px 6px; border:1px solid currentColor; border-radius:4px;">${status?.toUpperCase()}</span>`;
			}

			if (modalPhaseContent && tasksJson) {
				const tasks = JSON.parse(tasksJson);
				
				if (tasks.length === 0) {
					modalPhaseContent.innerHTML = `<p style="opacity:0.6; text-align:center; padding:2rem;">NO_TASKS_DEFINED</p>`;
				} else {
					// Ensure the container is focusable for keyboard/trackpad scrolling
					modalPhaseContent.setAttribute("tabindex", "0");
					
					const listHtml = tasks.map((t: any) => {
						const isDone = t.status === 'done';
						const isDoing = t.status === 'doing';
						const statusIcon = isDone ? '[x]' : isDoing ? '[/]' : '[ ]';
						const statusClass = t.status;
						
						
						return `
							<div class="modal-task-item">
								<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.5rem;">
									<span class="task-status-badge ${statusClass}">${statusIcon === '[x]' ? 'DONE' : statusIcon === '[/]' ? 'DOING' : 'PENDING'}</span>
									<span style="font-size:0.7rem; color:var(--muted); font-family:var(--font-mono);">
										${t.deadline ? `DUE: ${t.deadline}` : ''}
									</span>
								</div>
								<div style="font-weight:700; font-size:1rem; color:var(--fg); margin-bottom:0.5rem; ${isDone ? 'text-decoration:line-through; opacity:0.6;' : ''}">
									${t.title}
								</div>
								${t.content ? `<div style="font-size:0.85rem; opacity:0.8; line-height:1.5; white-space: pre-wrap;">${t.content.replace(/^---[\s\S]*?---\n?/, "")}</div>` : ''}
								<div style="margin-top:0.8rem; border-top:1px solid rgba(255,255,255,0.05); padding-top:0.5rem; font-size:0.7rem; color:var(--muted); display:flex; gap:1rem;">
									<span>PRIORITY: <span style="color:${t.priority === 'high' ? '#ff4d4d' : 'inherit'}">${t.priority?.toUpperCase() || 'MEDIUM'}</span></span>
									<span style="opacity:0.5;">FILE: ${t.id}</span>
								</div>
							</div>
						`;
					}).join('');
					
					modalPhaseContent.innerHTML = listHtml;
				}
			}

			phaseModal?.classList.add("active");
			document.body.style.overflow = "hidden";
		});
	});

	closePhaseBtn?.addEventListener("click", () => {
		phaseModal?.classList.remove("active");
		document.body.style.overflow = "auto";
	});
</script>

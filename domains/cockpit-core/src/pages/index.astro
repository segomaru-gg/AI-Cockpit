---
import Layout from "../layouts/Layout.astro";
import TaskCard from "../components/TaskCard.astro";
import ProgressBar from "../components/ProgressBar.astro";
import ActivityGrid from "../components/ActivityGrid.astro";
import GitStatus from "../components/GitStatus.astro";
import { discoverProjects, loadGlobalGoals } from "../lib/projects";
import path from "node:path";

const cockpitRoot = path.resolve(process.cwd(), "../");
const globalGoals = loadGlobalGoals(cockpitRoot);
const allProjects = await discoverProjects(cockpitRoot);
// Sort projects by global alignment score (highest first)
const projects = allProjects.sort((a, b) => b.globalAlignment - a.globalAlignment);

// Global Activity Aggregation
const globalActivity: Record<string, number> = {};
projects.forEach((p) => {
	Object.entries(p.activity).forEach(([date, count]) => {
		globalActivity[date] = (globalActivity[date] || 0) + count;
	});
});

// Aggregate statistics
const allTasks = projects.flatMap((p) => p.tasks);
const projectStats = {
	total: allTasks.length,
	done: allTasks.filter((t) => t.status === "done").length,
	doing: allTasks.filter((t) => t.status === "doing").length,
	projectsCount: projects.length,
};

const overallProgress =
	projectStats.projectsCount > 0
		? projects.reduce((acc, p) => acc + (p.activeGoal ? p.activeGoal.progress : 0), 0) /
		  projectStats.projectsCount
		: 0;

const getAdvice = (projects: any[], globalGoals: any) => {
	const today = new Date();
	today.setHours(0, 0, 0, 0);

	// 1. Critical: Phase Deadline Approaches (within 2 weeks)
	for (const p of projects) {
		if (p.activeGoal) {
			for (const phase of p.activeGoal.phases) {
				if (phase.status === 'active' && phase.deadline) {
					const d = new Date(phase.deadline);
					const diffTime = d.getTime() - today.getTime();
					const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

					if (diffDays < 0) {
						return `[CRITICAL] ${p.name} - ${phase.name} の期限 (${phase.deadline}) を超過しています。直ちに対処してください。`;
					}
					if (diffDays <= 14) {
						return `[URGENT] ${p.name} - ${phase.name} の期限まであと ${diffDays} 日です (${phase.deadline})。優先的に進めてください。`;
					}
				}
			}
		}
	}

	// 2. Strategy: High-alignment domain with no recent activity
	if (globalGoals) {
		const highAligned = projects
			.filter(p => p.globalAlignment >= 4)
			.sort((a: any, b: any) => b.globalAlignment - a.globalAlignment);

		for (const p of highAligned) {
			const recentDays = Object.keys(p.activity).filter(d => {
				const diff = today.getTime() - new Date(d).getTime();
				return diff < 7 * 24 * 60 * 60 * 1000;
			});
			if (recentDays.length === 0) {
				return `[STRATEGY] ${p.name} はグローバル目標への貢献度が高い (★${Math.round(p.globalAlignment)}) ですが、直近7日間の活動がありません。優先的に着手してください。`;
			}
		}

		// 3. Balance: Low-alignment domain consuming too much focus
		const lowAligned = projects.filter(p => p.globalAlignment <= 2);
		for (const p of lowAligned) {
			const recentDays = Object.keys(p.activity).filter(d => {
				const diff = today.getTime() - new Date(d).getTime();
				return diff < 7 * 24 * 60 * 60 * 1000;
			});
			if (recentDays.length >= 5) {
				const topProject = highAligned[0];
				if (topProject) {
					return `[BALANCE] ${p.name} への集中が見られますが、グローバル目標との整合度が低いです。${topProject.name} の進捗を確認してください。`;
				}
			}
		}
	}

	// 4. Warning: Active Phases without Deadlines
	const noDeadlinePhase = projects.find(p => p.activeGoal?.phases.some((ph: any) => ph.status === 'active' && !ph.deadline));
	if (noDeadlinePhase) {
		return `[ATTENTION] ${noDeadlinePhase.name} のActive Phaseに期限が設定されていません。phase.yamlにdeadlineを追加してください。`;
	}

	// 5. General Advice based on lowest progress
	const lowestProject = projects
		.filter(p => p.activeGoal && p.activeGoal.progress < 100)
		.sort((a, b) => (a.activeGoal?.progress || 0) - (b.activeGoal?.progress || 0))[0];

	if (lowestProject) {
		return `順調です。進捗が最も低い ${lowestProject.name} (${lowestProject.activeGoal?.progress}%) のタスク消化に注力しましょう。`;
	}

	return "全プロジェクトの目標が達成されています。新たなGoalを設定するか、次のフェーズへ移行してください。";
};

// Domain categories (auto-derived from folder structure)
const domainCategories = [...new Set(projects.map(p => p.category))].sort();

	// Focus First Logic: Identify the "Current Mission"
	// Priority: BluePrint > Others, then by lowest progress active goal.
	const currentMission = projects.find(p => p.name === 'BluePrint' && p.activeGoal && p.activeGoal.progress < 100) 
		|| projects.find(p => p.activeGoal && p.activeGoal.progress < 100);

	const missionPhase = currentMission?.activeGoal?.phases.find(p => p.status === 'active');
---

<Layout title="Cockpit Dashboard">
	<header class="dashboard-header">
		
		<div class="top-bar">
			<div class="global-identity">
				<span class="system-label">UNIFIED_COCKPIT // GLOBAL_VIEW</span>
				<h1>MASTER CONTROL DASHBOARD</h1>
			</div>
			<div class="system-meta">
				<a href="/focus" class="focus-link">[ENTER_FOCUS_MODE]</a>
				<span class="system-label">v2.1.6 // {new Date().toLocaleDateString('ja-JP')}</span>
			</div>
		</div>



		<div class="global-stats-bar">
			<div class="stat-group">
				<span class="stat-label">GLOBAL_PROGRESS</span>
				<ProgressBar progress={overallProgress} label="" />
			</div>
			<div class="stat-items">
				<div class="mini-stat">
					<span class="label">ACTIVE_PROJECTS</span>
					<span class="value">{projectStats.projectsCount}</span>
				</div>
				<div class="mini-stat">
					<span class="label">TOTAL_TASKS</span>
					<span class="value">{projectStats.total}</span>
				</div>
			</div>
		</div>

		<div class="advice-panel">
			<span class="system-label">AI_TACTICAL_ADVICE //</span>
			<p class="advice-text">{getAdvice(projects, globalGoals)}</p>
		</div>

		{globalGoals && globalGoals.goals.length > 0 && (
			<div class="global-goals-section">
				<span class="system-label">GLOBAL_OBJECTIVE // {globalGoals.current_quarter}</span>
				<div class="global-goals-list">
					{globalGoals.goals.map((g, i) => (
						<div class="global-goal-card">
							<div class="goal-priority-badge">P{g.priority}</div>
							<div class="goal-info">
								<span class="goal-name">{g.title}</span>
								<span class="goal-desc">{g.description}</span>
							</div>
						</div>
					))}
				</div>
			</div>
		)}

		<nav class="filter-bar">
			<div class="filter-main">
				<div class="filter-buttons">
					<button class="filter-btn active cat-all" data-filter="all">ALL</button>
					{domainCategories.map((cat) => (
						<button class={`filter-btn cat-${cat}`} data-filter={cat}>{cat}</button>
					))}
				</div>
				<div class="search-box">
					<input type="text" id="dashboard-search" placeholder="Filter projects..." />
				</div>
			</div>
		</nav>
	</header>

	<div class="blueprint-grid" id="project-grid">
		{
			projects.map((project) => (
				<section
					class="project-section"
					data-category={project.category}
				>
					<div class="project-header">
						<div class="project-meta">
							<span
								class={`category-badge cat-${project.category}`}
							>
								{project.category}
							</span>
							<span class="system-label">PROJECT_MODULE</span>
							{project.globalAlignment > 0 && (
								<span class="alignment-badge" title={`Global Alignment: ${project.globalAlignment}/5`}>
									{'★'.repeat(Math.round(project.globalAlignment))}{'☆'.repeat(5 - Math.round(project.globalAlignment))}
								</span>
							)}
							<h2>{project.name}</h2>
						</div>
						<div class="project-activity">
							<span class="system-label">PROJECT_MOMENTUM /</span>
							<ActivityGrid
								activity={project.activity}
								size="small"
							/>
						</div>
						{project.latestLog && (
							<div class="latest-log">
								<span class="log-title">
									LATEST_LOG: {project.latestLog}
								</span>
								{project.latestLogPreview && (
									<p class="log-content">
										{project.latestLogPreview}
									</p>
								)}
								{project.latestLogFull && (
									<button
										class="view-log-btn"
										data-log-title={project.latestLog}
										data-log-body={project.latestLogFull}
									>
										[VIEW_FULL_LOG]
									</button>
								)}
							</div>
						)}
						
						<!-- Project-level ProgressBar Removed as per request -->

						<!-- Multi-Goal Rendering -->
						{project.activeGoals && project.activeGoals.length > 0 ? (
							project.activeGoals.map((goal) => (
								<div class="goal-container">
									<div class="goal-header">
										<span class="system-label">GOAL_{goal.id.toUpperCase()} //</span>
										<div style="display: flex; justify-content: space-between; align-items: center;">
											<h3 class="goal-title">{goal.title}</h3>
											<span class="system-label">PROGRESS: {goal.progress}%</span>
										</div>
									</div>
									
									<div class="phase-timeline">
										{goal.phases.filter(p => p.status === 'active').map((phase) => (
											<div 
												class={`phase-card ${phase.status}`} 
												tabindex="0"
												data-phase-name={phase.name}
												data-phase-status={phase.status}
												data-phase-tasks={JSON.stringify(phase.tasks || [])}
											>
												<div class="phase-header">
													<span class="phase-name">{phase.name}</span>
													<span class="phase-badge">{phase.status}</span>
												</div>
												<div class="phase-progress-bar">
													<div class="progress-fill" style={`width: ${phase.progress}%`}></div>
												</div>
												<div class="phase-meta">
													<span class="progress-text">{phase.progress}% COMPLETED</span>
													{phase.deadline && (
														<span class={`phase-deadline ${new Date(phase.deadline) < new Date() ? 'overdue' : ''}`}>
															DUE: {phase.deadline}
														</span>
													)}
												</div>
											</div>
										))}
									</div>
								</div>
							))
						) : (
							project.activeGoal && (
								<div class="goal-container">
									<div class="goal-header">
										<span class="system-label">CURRENT_TARGET //</span>
										<h3 class="goal-title">{project.activeGoal.title}</h3>
									</div>
									
									<div class="phase-timeline">
										{project.activeGoal.phases.filter(p => p.status === 'active').map((phase) => (
											<div 
												class={`phase-card ${phase.status}`} 
												tabindex="0"
												data-phase-name={phase.name}
												data-phase-status={phase.status}
												data-phase-tasks={JSON.stringify(phase.tasks || [])}
											>
												<div class="phase-header">
													<span class="phase-name">{phase.name}</span>
													<span class="phase-badge">{phase.status}</span>
												</div>
												<div class="phase-progress-bar">
													<div class="progress-fill" style={`width: ${phase.progress}%`}></div>
												</div>
												<div class="phase-meta">
													<span class="progress-text">{phase.progress}% COMPLETED</span>
													{phase.deadline && (
														<span class={`phase-deadline ${new Date(phase.deadline) < new Date() ? 'overdue' : ''}`}>
															DUE: {phase.deadline}
														</span>
													)}
												</div>
											</div>
										))}
									</div>
								</div>
							)
						)}
					</div>
					<!-- Task List Removed as per request -->
				</section>
			))
		}
	</div>

	<footer class="dashboard-footer">
		<div class="footer-line"></div>
		<div class="footer-content">
			<span>COCKPIT_LINK_STABLE</span>
			<span>MULTI_DOMAIN // AGGREGATED</span>
			<span>{new Date().toISOString()}</span>
		</div>
	</footer>

	<!-- Journal Modal -->
	<div id="journal-modal" class="modal-overlay">
		<div class="modal-container">
			<header class="modal-header">
				<h2 id="modal-log-title">LOG_TITLE</h2>
				<button id="close-journal-modal" class="close-btn"
					>CLOSE [X]</button
				>
			</header>
			<div class="modal-body">
				<pre id="modal-log-content"></pre>
			</div>
		</div>
	</div>

	<!-- Task Detail Modal -->
	<div id="task-modal" class="modal-overlay">
		<div class="modal-container task-modal-container">
			<header class="modal-header">
				<h2 id="modal-task-title">TASK_TITLE</h2>
				<button id="close-task-modal" class="close-btn"
					>CLOSE [X]</button
				>
			</header>
			<div class="modal-body">
				<div id="modal-task-content" class="markdown-body"></div>
			</div>
		</div>
	</div>

	<!-- Phase Tasks Modal -->
	<div id="phase-modal" class="modal-overlay">
		<div class="modal-container phase-modal-container">
			<header class="modal-header">
				<h2 id="modal-phase-title">PHASE_TITLE</h2>
				<button id="close-phase-modal" class="close-btn">CLOSE [X]</button>
			</header>
			<div class="modal-body">
				<div id="modal-phase-content" class="phase-tasks-list-modal"></div>
			</div>
		</div>
	</div>
</Layout>

<!-- Force HMR Reload for moving goal: 2026-q1-concept-driven to brand -->


---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Products from "../components/Products.astro";
import Philosophy from "../components/Philosophy.astro";
---

<Layout title="Aeternum - meaning to be inherited">
	<main>
		<Hero />
		<Products />
		<Philosophy />
	</main>

	<footer class="footer">
		<div class="container">
			<div class="footer-content">
				<div class="brand">Aeternum</div>
				<ul class="links">
					<li>
						<a
							href="https://instagram.com"
							target="_blank"
							rel="noopener noreferrer">Instagram</a
						>
					</li>
					<li>
						<a
							href="https://twitter.com"
							target="_blank"
							rel="noopener noreferrer">X (Twitter)</a
						>
					</li>
					<li><a href="mailto:contact@example.com">Contact</a></li>
				</ul>
			</div>
			<div class="copyright">
				&copy; {new Date().getFullYear()} Aeternum. All rights reserved.<br
				/>
				powered by Aeternum
			</div>
		</div>
	</footer>
</Layout>

<style>
	main {
		width: 100%;
	}

	.footer {
		padding: 4rem 0 2rem;
		border-top: 1px solid rgba(0, 0, 0, 0.05);
		background: transparent;
	}

	.footer-content {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 3rem;
		flex-wrap: wrap;
		gap: 2rem;
	}

	.brand {
		font-family: "Outfit", sans-serif;
		font-size: 1.5rem;
		font-weight: 500;
		letter-spacing: 0.05em;
	}

	.links {
		display: flex;
		list-style: none;
		gap: 2rem;
	}

	.links a {
		color: var(--text-muted);
		font-family: "Outfit", sans-serif;
		font-size: 0.9rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.copyright {
		text-align: center;
		color: var(--text-muted);
		font-size: 0.8rem;
		opacity: 0.7;
		margin-top: 2rem;
		line-height: 1.8;
	}

	/* Simple reveal animation script placeholder */
	.reveal {
		opacity: 0;
		transform: translateY(30px);
		transition: all 0.8s ease-out;
	}

	.reveal.active {
		opacity: 1;
		transform: translateY(0);
	}
</style>

<script>
	// Simple Intersection Observer setup for scroll animations
	document.addEventListener("DOMContentLoaded", () => {
		const revealElements = document.querySelectorAll(
			".product-card, .info-card",
		);

		const revealObserver = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						const el = entry.target as HTMLElement;
						el.classList.add("active");
						el.style.opacity = "1";
						el.style.transform = "translateY(0)";
						revealObserver.unobserve(el);
					}
				});
			},
			{
				threshold: 0.1,
				rootMargin: "0px 0px -50px 0px",
			},
		);

		// Apply initial styles for the observer to work
		revealElements.forEach((element) => {
			const el = element as HTMLElement;
			el.style.opacity = "0";
			el.style.transform = "translateY(30px)";
			el.style.transition = "all 0.8s cubic-bezier(0.165, 0.84, 0.44, 1)";
			revealObserver.observe(el);
		});
	});
</script>
